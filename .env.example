# Configuracion general
PROJECT_NAME=project_final
API_V1_STR=/api/v1
DEBUG=true

# Opcion 1: usar una URL completa de SQLAlchemy
# DATABASE_URL=postgresql+psycopg2://postgres:12345678@localhost:5432/User

# Opcion 2: construir la URL con piezas separadas
DB_USER=postgres
DB_PASSWORD=12345678
DB_HOST=localhost
DB_PORT=5432
DB_NAME=User

# JWT
# Usa una cadena larga y aleatoria en JWT_SECRET_KEY.
JWT_SECRET_KEY=pon-aqui-una-clave-secreta-larga
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
